  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9B7F86",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#A95D83",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#C66F4E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#6D74AA"
      }
    },
    {
      "scope": [
        "entity.name.interface",
        "support.type.interface"
      ],
      "settings": {
        "foreground": "#4F8FA3"
      }
    },
    {
      "scope": [
        "entity.name.enum",
        "support.type.enum"
      ],
      "settings": {
        "foreground": "#B7833F"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#4E8A72"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#D18B32"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#334052"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#7C6E7C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#4C8C98"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B36F3D"
      }
    },
    {
      "scope": [
        "meta.annotation",
        "storage.type.annotation",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#C7546E"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#667A95"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#827781"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#C84E63"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#6D74AA",
    "type": "#6D74AA",
    "class": {
      "foreground": "#6D74AA",
      "bold": true
    },
    "interface": "#4F8FA3",
    "enum": "#B7833F",
    "function": {
      "foreground": "#C66F4E",
      "bold": true
    },
    "method": {
      "foreground": "#C66F4E",
      "bold": true
    },
    "property": "#667A95",
    "variable": "#334052",
    "parameter": {
      "foreground": "#7C6E7C",
      "italic": true
    },
    "keyword": {
      "foreground": "#A95D83",
      "bold": true
    },
    "string": "#4E8A72",
    "number": "#D18B32",
    "comment": {
      "foreground": "#9B7F86",
      "italic": true
    },
    "decorator": "#C7546E"
  }
}