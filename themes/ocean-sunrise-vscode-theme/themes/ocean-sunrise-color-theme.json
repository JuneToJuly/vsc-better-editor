  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8196A2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#2F78A8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#C96F3B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#5479B6"
      }
    },
    {
      "scope": [
        "entity.name.interface",
        "support.type.interface"
      ],
      "settings": {
        "foreground": "#388FA3"
      }
    },
    {
      "scope": [
        "entity.name.enum",
        "support.type.enum"
      ],
      "settings": {
        "foreground": "#B98939"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#4F8D73"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#D58E25"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#294153"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#6D7F8E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#3689A0"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B26E35"
      }
    },
    {
      "scope": [
        "meta.annotation",
        "storage.type.annotation",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#C75568"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#5D7590"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#7C8990"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#C84E63"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#5479B6",
    "type": "#5479B6",
    "class": {
      "foreground": "#5479B6",
      "bold": true
    },
    "interface": "#388FA3",
    "enum": "#B98939",
    "function": {
      "foreground": "#C96F3B",
      "bold": true
    },
    "method": {
      "foreground": "#C96F3B",
      "bold": true
    },
    "property": "#5D7590",
    "variable": "#294153",
    "parameter": {
      "foreground": "#6D7F8E",
      "italic": true
    },
    "keyword": {
      "foreground": "#2F78A8",
      "bold": true
    },
    "string": "#4F8D73",
    "number": "#D58E25",
    "comment": {
      "foreground": "#8196A2",
      "italic": true
    },
    "decorator": "#C75568"
  }
}