  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7186A2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#A9C7FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#8ED9FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#C3B5F3"
      }
    },
    {
      "scope": [
        "entity.name.interface",
        "support.type.interface"
      ],
      "settings": {
        "foreground": "#8DD6E8"
      }
    },
    {
      "scope": [
        "entity.name.enum",
        "support.type.enum"
      ],
      "settings": {
        "foreground": "#D7D9EE"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#9EDCC6"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#D6C7A0"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#DDE7F5"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#AABBD0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#87C7E1"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B6C8E0"
      }
    },
    {
      "scope": [
        "meta.annotation",
        "storage.type.annotation",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#D29FEF"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#88BFE8"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#8EA0B6"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#B94D68"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#C3B5F3",
    "type": "#C3B5F3",
    "class": {
      "foreground": "#C3B5F3",
      "bold": true
    },
    "interface": "#8DD6E8",
    "enum": "#D7D9EE",
    "function": {
      "foreground": "#8ED9FF",
      "bold": true
    },
    "method": {
      "foreground": "#8ED9FF",
      "bold": true
    },
    "property": "#AABBD0",
    "variable": "#DDE7F5",
    "parameter": {
      "foreground": "#AABBD0",
      "italic": true
    },
    "keyword": {
      "foreground": "#A9C7FF",
      "bold": true
    },
    "string": "#9EDCC6",
    "number": "#D6C7A0",
    "comment": {
      "foreground": "#7186A2",
      "italic": true
    },
    "decorator": "#D29FEF"
  }
}