  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#BDD4ED",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#D4F7EA"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#FFF3B0"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#E6EBF4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#DDE8FF"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#F4F8FD"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#D8F1FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#C5F4FF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#D8F1FF"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#C5F4FF"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#BDD4ED"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#A84B5B"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#DDE8FF",
    "type": "#DDE8FF",
    "class": {
      "foreground": "#E6EBF4",
      "bold": true
    },
    "interface": "#C5F4FF",
    "enum": "#E0D2FF",
    "function": {
      "foreground": "#FFFFFF",
      "bold": true
    },
    "method": {
      "foreground": "#FFFFFF",
      "bold": true
    },
    "property": "#D8F1FF",
    "variable": "#F4F8FD",
    "parameter": {
      "foreground": "#D8F1FF",
      "italic": true
    },
    "keyword": {
      "foreground": "#FFFFFF",
      "bold": true
    },
    "string": "#D4F7EA",
    "number": "#FFF3B0",
    "comment": {
      "foreground": "#BDD4ED",
      "italic": true
    },
    "decorator": "#E0D2FF"
  }
}