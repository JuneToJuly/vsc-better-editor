  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#C9845F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D77CF4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#FF9B6A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#B9A2F4"
      }
    },
    {
      "scope": [
        "entity.name.interface",
        "support.type.interface"
      ],
      "settings": {
        "foreground": "#7EC6E8"
      }
    },
    {
      "scope": [
        "entity.name.enum",
        "support.type.enum"
      ],
      "settings": {
        "foreground": "#F1C76A"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#D9D66F"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#FFB347"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#F2C7B7"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#EAB0A5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#F47B8D"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#EFB06A"
      }
    },
    {
      "scope": [
        "meta.annotation",
        "storage.type.annotation",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#FF7272"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#FFA060"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#D4B6A9"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#C43858"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#B9A2F4",
    "type": "#B9A2F4",
    "class": {
      "foreground": "#B9A2F4",
      "bold": true
    },
    "interface": "#7EC6E8",
    "enum": "#F1C76A",
    "function": {
      "foreground": "#FF9B6A",
      "bold": true
    },
    "method": {
      "foreground": "#FF9B6A",
      "bold": true
    },
    "property": "#F2A07E",
    "variable": "#F2C7B7",
    "parameter": {
      "foreground": "#EAB0A5",
      "italic": true
    },
    "keyword": {
      "foreground": "#D77CF4",
      "bold": true
    },
    "string": "#D9D66F",
    "number": "#FFB347",
    "comment": {
      "foreground": "#C9845F",
      "italic": true
    },
    "decorator": "#FF7272"
  }
}