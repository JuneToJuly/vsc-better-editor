  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7E7B5E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#E6D73F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#D97745",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#B7A05D"
      }
    },
    {
      "scope": [
        "entity.name.interface",
        "support.type.interface"
      ],
      "settings": {
        "foreground": "#83A68C"
      }
    },
    {
      "scope": [
        "entity.name.enum",
        "support.type.enum"
      ],
      "settings": {
        "foreground": "#C7B04A"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#93B15A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#E7C63E"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#E7D9A8"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#B8AC86",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#7FA08D"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#C58A3A"
      }
    },
    {
      "scope": [
        "meta.annotation",
        "storage.type.annotation",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#C64A3D"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#B79C51"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#8D896E"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#A9352D"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#B7A05D",
    "type": "#B7A05D",
    "class": {
      "foreground": "#B7A05D",
      "bold": true
    },
    "interface": "#83A68C",
    "enum": "#C7B04A",
    "function": {
      "foreground": "#D97745",
      "bold": true
    },
    "method": {
      "foreground": "#D97745",
      "bold": true
    },
    "property": "#B79C51",
    "variable": "#E7D9A8",
    "parameter": {
      "foreground": "#B8AC86",
      "italic": true
    },
    "keyword": {
      "foreground": "#E6D73F",
      "bold": true
    },
    "string": "#93B15A",
    "number": "#E7C63E",
    "comment": {
      "foreground": "#7E7B5E",
      "italic": true
    },
    "decorator": "#C64A3D"
  }
}